{
  "permissions": {
    "allow": [
      "PowerShell(npm install zod @hono/zod-validator)",
      "PowerShell(npx tsc --noEmit)",
      "PowerShell(npm install -D typescript)",
      "PowerShell(npx wrangler dev --port 8787)",
      "Bash(seq 1 30)",
      "Bash(curl -s -o /dev/null http://127.0.0.1:8787/health)",
      "Bash(break)",
      "Bash(sleep 1)",
      "Bash(echo \"health:\")",
      "PowerShell(npm install -D @cloudflare/workers-types)",
      "Bash(curl -s -w \"\\\\nstatus:%{http_code}\" -X POST http://127.0.0.1:8787/contact -H \"Content-Type: application/json\" -d '{\"name\":\"test\",\"email\":\"a@b.com\",\"message\":\"hello\"}')",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:developers.cloudflare.com)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" -X POST https://httpbin.org/post -H \"Content-Type: application/json\" -d '{}')",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" -X POST https://postman-echo.com/post -H \"Content-Type: application/json\" -d '{}')",
      "WebFetch(domain:blog.cloudflare.com)"
    ]
  }
}
